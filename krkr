    local function EquipToolByType(ttype)
        pcall(function()
            if not Plr.Character then return end
            local h = Plr.Character:FindFirstChild("Humanoid"); if not h then return end
            local t = Plr.Character:FindFirstChildOfClass("Tool")
            if t and (t.ToolTip == ttype or (ttype=="Gun" and t.ToolTip=="Guns")) then return end
            for _, t2 in pairs(Plr.Backpack:GetChildren()) do
                if t2:IsA("Tool") and (t2.ToolTip == ttype or (ttype=="Gun" and t2.ToolTip=="Guns")) then 
                    h:EquipTool(t2); return 
                end
            end
        end)
    end

    local function IsBuddhaFruit()
        local t = Plr.Character and Plr.Character:FindFirstChildOfClass("Tool")
        if not t then
            for _, t2 in pairs(Plr.Backpack:GetChildren()) do
                if t2:IsA("Tool") and t2.ToolTip == "Blox Fruit" then t = t2; break end
            end
        end
        return t and string.find(string.lower(t.Name), "buddha") ~= nil
    end

    local function ShouldUseFinisher()
        if not State.CurrentTarget or not State.CurrentTarget.Instance then return false end
        local h = State.CurrentTarget.Instance:FindFirstChild("Humanoid")
        return h and h.Health <= Settings.SwitchHP
    end

    local function EquipWeapon()
        local wm = State.WeaponMode
        if wm == "Melee" then EquipToolByType("Melee")
        elseif wm == "Sword" then EquipToolByType("Sword")
        elseif wm == "Gun" then EquipToolByType("Gun")
        elseif wm == "Fruit" then EquipToolByType("Blox Fruit")
        elseif wm == "MeleeGun" then if ShouldUseFinisher() then EquipToolByType("Gun") else EquipToolByType("Melee") end
        elseif wm == "MeleeAbility" then if ShouldUseFinisher() then EquipToolByType("Blox Fruit") else EquipToolByType("Melee") end
        end
    end

    local function GetSmartQuest()
        if State.QuestLocked and State.LockedQuestData then 
            return State.LockedQuestData 
        end

        local ml = GetMyLevel()
        local bestQuest = LevelUpDatabase[1]
        local prevNormalQuest = LevelUpDatabase[1]

        for _, d in ipairs(LevelUpDatabase) do
            if ml >= d.Lvl then
                bestQuest = d
                if not d.IsBoss then prevNormalQuest = d end
            end
        end

        if not bestQuest then return nil end

        if bestQuest.IsBoss then
            if not State.BossInLevelUp then return prevNormalQuest end
            if not IsBossSpawned(bestQuest.Mob) then return prevNormalQuest end
        end

        return bestQuest
    end

