    -- Tick: منطق اصلی لول آپ و مدیریت Cursed Ship
    -- ═══════════════════════════════════════
    local function Tick(Root, now)
        if not State.Enabled then return end

        -- 🟢 === بخش جدید: کشتن ماب های اطراف === 🟢
        if State.KillSurrounding then
            -- اگر الان روی یک ماب قفل هستیم و هنوز زنده است، ولش نکن
            if State.CurrentTarget and State.CurrentTarget.Mode == "Mob" and State.CurrentTarget.Instance then
                if IsEnemyValid(State.CurrentTarget.Instance) then
                    PrepareEnemy(State.CurrentTarget.Instance)
                    State.IsSafeToClick = true
                    return
                else
                    CleanupExpandedHead(State.CurrentTarget.Instance)
                    if State.CurrentExpandedEnemy == State.CurrentTarget.Instance then State.CurrentExpandedEnemy = nil end
                    State.CurrentTarget = nil
                end
            end

            -- پیدا کردن نزدیک‌ترین ماب برای کشتن
            local nearest = nil
            local minDist = 350
            local enemies = Workspace:FindFirstChild("Enemies")
            if enemies then
                for _, v in pairs(enemies:GetChildren()) do
                    pcall(function()
                        if IsEnemyValid(v) then
                            local d = (Root.Position - v.HumanoidRootPart.Position).Magnitude
                            if d < minDist then
                                minDist = d
                                nearest = v
                            end
                        end
                    end)
                end
            end

            if nearest then
                PrepareEnemy(nearest)
                State.CurrentTarget = {Mode="Mob", Instance=nearest}
                State.IsSafeToClick = true
            else
                State.CurrentTarget = nil
                State.IsSafeToClick = false
            end
            
            return -- 👈 این باعث میشه وقتی دکمه روشنه، کدهای کوئست پایین اصلاً اجرا نشن
        end
        -- 🔴 ===================================== 🔴


        -- کدهای اورجینال خودت برای لول آپ از اینجا ادامه داره:
        local QData = GetSmartQuest()
        if not QData then return end

        -- مدیریت ورود و خروج از Cursed Ship (مخصوص دریای دوم)
        if Sea == 2 then
            -- مختصات مرکز کشتی به صورت تقریبی
            local shipCenter = Vector3.new(923, 126, 32852)
            local inShip = (Root.Position - shipCenter).Magnitude < 3000

            -- اگر لول کوئست بین 1250 تا 1325 است (نیاز به بودن در کشتی)
            if QData.Lvl >= 1250 and QData.Lvl <= 1325 then
                if not inShip then
                    -- توقف حرکت قبل از تلپورت
                    if State.ActiveTween then State.ActiveTween:Cancel(); State.ActiveTween = nil end
                    pcall(function()
                        ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(923.213, 126.976, 32852.832))
                    end)
                    task.wait(2)
                    return -- متوقف کردن بقیه کدها تا تلپورت کامل شود
                end
            -- اگر لول کوئست بیشتر از 1325 است (یا کمتر) و پلیر داخل کشتی گیر کرده
            elseif QData.Lvl > 1325 and inShip then
                -- توقف حرکت قبل از تلپورت
                if State.ActiveTween then State.ActiveTween:Cancel(); State.ActiveTween = nil end
                pcall(function()
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(-6508.558, 89.035, -132.84))
                end)
                task.wait(2)
                return -- متوقف کردن بقیه کدها تا تلپورت کامل شود
            end
        end

        -- ادامه روند عادی لول‌آپ
        if HasQuest() then
            State.IsSafeToClick = true
            
            if not State.QuestLocked then
                State.QuestLocked = true
                State.LockedQuestData = QData
            end

            if State.CurrentTarget and State.CurrentTarget.Mode == "Mob" and State.CurrentTarget.Instance then
                if IsEnemyValid(State.CurrentTarget.Instance) then
                    PrepareEnemy(State.CurrentTarget.Instance); return
                else
                    CleanupExpandedHead(State.CurrentTarget.Instance)
                    if State.CurrentExpandedEnemy == State.CurrentTarget.Instance then State.CurrentExpandedEnemy = nil end
                    State.CurrentTarget = nil
                end
            end

            local fm, md = nil, math.huge
            local targetMob = State.LockedQuestData.Mob
            if Workspace:FindFirstChild("Enemies") then
                for _, v in pairs(Workspace.Enemies:GetChildren()) do
                    pcall(function()
                        if string.find(v.Name, targetMob) and IsEnemyValid(v) then
                            local d = (Root.Position - v.HumanoidRootPart.Position).Magnitude
                            if d < md then md = d; fm = v end
                        end
                    end)
                end
            end

            if fm then
                PrepareEnemy(fm)
                State.CurrentTarget = {Mode="Mob", Instance=fm}
                State.LastKnownSpawn = fm.HumanoidRootPart.CFrame
            else
                if State.CurrentExpandedEnemy then CleanupExpandedHead(State.CurrentExpandedEnemy); State.CurrentExpandedEnemy = nil end
                local sp = GetAggressiveSpawn(targetMob)
                if sp then State.CurrentTarget = {Mode="Wait", CFrame=sp*CFrame.new(0,Settings.WaitHeight,0)}
                elseif State.LastKnownSpawn then State.CurrentTarget = {Mode="Wait", CFrame=State.LastKnownSpawn*CFrame.new(0,Settings.WaitHeight,0)}
                else State.CurrentTarget = {Mode="Wait", CFrame=QData.Pos*CFrame.new(0,50,0)} end
            end
        else
            if State.QuestLocked then 
                State.QuestLocked = false; State.LockedQuestData = nil 
            end

            if State.CurrentExpandedEnemy then CleanupExpandedHead(State.CurrentExpandedEnemy); State.CurrentExpandedEnemy = nil end
            State.LastKnownSpawn = nil
            State.IsSafeToClick = false

            local freshQData = GetSmartQuest()
            if not freshQData then return end

            State.CurrentTarget = {Mode="NPC", CFrame=freshQData.Pos}
            if (Root.Position - freshQData.Pos.Position).Magnitude < 15 then
                pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", freshQData.QName, freshQData.QId) end)
            end
        end
    end

    -- ═══════════════════════════════════════
    -- لوپ حمله و حرکت 
    -- ═══════════════════════════════════════
    task.spawn(function()
        while task.wait(0.1) do
            pcall(function()
                if not State.Enabled or not State.IsSafeToClick then return end
                if not State.CurrentTarget or State.CurrentTarget.Mode ~= "Mob" or not State.CurrentTarget.Instance then return end

                local E = State.CurrentTarget.Instance
                if E ~= State.LastTargetEnemy then State.LastTargetEnemy = E; State.LastTargetTime = tick() end
                if tick() - State.LastTargetTime < Settings.AttackWaitTime then return end

                if not IsEnemyValid(E) then return end
                if not Plr.Character or not Plr.Character:FindFirstChild("Humanoid") then return end

                pcall(function()
                    if E:FindFirstChild("Head") then
                        Workspace.CurrentCamera.CFrame = CFrame.lookAt(Workspace.CurrentCamera.CFrame.Position, E.Head.Position)
                    end
                end)

                EquipWeapon()
                
                local CX, CY = Workspace.CurrentCamera.ViewportSize.X/2, Workspace.CurrentCamera.ViewportSize.Y/2
                VirtualInputManager:SendMouseButtonEvent(CX, CY, 0, true, game, 1)
                task.wait(Settings.HoldTime)
                VirtualInputManager:SendMouseButtonEvent(CX, CY, 0, false, game, 1)
                
                if State.AttackMethod == "Click" then
                    RegisterAttack:FireServer(math.floor((0.5 + math.random() * 0.5) * 10000) / 10000)
                elseif State.AttackMethod == "RemoteHit" then
                    local R = E:FindFirstChild("HumanoidRootPart"); if R then RegisterHit:FireServer(R) end
                end
            end)
        end
    end)

    task.spawn(function()
        while task.wait(0.1) do
            pcall(function()
                if not State.Enabled then return end
                if not Plr.Character or not Plr.Character:FindFirstChild("HumanoidRootPart") then return end
                local Root = Plr.Character.HumanoidRootPart
                local Dest = nil

                if State.CurrentTarget then
                    if State.CurrentTarget.Mode == "NPC" or State.CurrentTarget.Mode == "Wait" then
                        Dest = State.CurrentTarget.CFrame
                    elseif State.CurrentTarget.Mode == "Mob" and State.CurrentTarget.Instance then
                        pcall(function()
                            if State.CurrentTarget.Instance:FindFirstChild("HumanoidRootPart") then
                                local EP = State.CurrentTarget.Instance.HumanoidRootPart.Position
                                local d = (Root.Position - EP); d = Vector3.new(d.X, 0, d.Z)
                                if d.Magnitude < 0.1 then d = Vector3.new(1,0,0) end; d = d.Unit
                                
                                local ad, ah = Settings.AttackDistance, Settings.AttackHeight
                                if IsBuddhaFruit() then ad = Settings.BuddhaDistance end
                                Dest = CFrame.lookAt(EP + d * ad + Vector3.new(0, ah, 0), EP)
                            end
                        end)
                    end
                end

                if Dest then
                    if State.ActiveTween then State.ActiveTween:Cancel(); State.ActiveTween = nil end
                    local dist = (Root.Position - Dest.Position).Magnitude
                    if dist < 20 then 
                        Root.CFrame = Dest
                    else
                        State.ActiveTween = TweenService:Create(Root, TweenInfo.new(math.max(dist/Settings.FlightSpeed, 0.05), Enum.EasingStyle.Linear), {CFrame=Dest})
                        State.ActiveTween:Play()
                    end
                end
            end)
        end
    end)

    RunService.Heartbeat:Connect(function()
        pcall(function()
            if not State.Enabled then return end
            if Plr.Character then
                for _, p in pairs(Plr.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
                if Plr.Character:FindFirstChild("HumanoidRootPart") then Plr.Character.HumanoidRootPart.Velocity = Vector3.zero end
            end
        end)
    end)

    -- ═══════════════════════════════════════
    -- API خروجی
    -- ═══════════════════════════════════════
    local API = {}

    function API.Start()
        State.Enabled = true
        State.IsSafeToClick = true
        State.QuestLocked = false
        State.LockedQuestData = nil
    end

    function API.Stop()
        State.Enabled = false
        State.CurrentTarget = nil
        State.QuestLocked = false
        State.LockedQuestData = nil
        State.IsSafeToClick = true
        if State.CurrentExpandedEnemy then CleanupExpandedHead(State.CurrentExpandedEnemy); State.CurrentExpandedEnemy = nil end
        if State.ActiveTween then State.ActiveTween:Cancel(); State.ActiveTween = nil end
    end

    function API.SetWeaponMode(mode) State.WeaponMode = mode end
    function API.SetAttackMethod(method) State.AttackMethod = method end
    function API.SetBossInLevelUp(val) State.BossInLevelUp = val end
    function API.SetKillAura(val) State.KillSurrounding = val end -- 👈 این تابع متصل کننده دکمه به اسکریپت اصلیه
    function API.Tick(Root, now) Tick(Root, now) end

    return API
end
