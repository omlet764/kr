-- FightingStyleModule.lua
return function(WindUI, ReplicatedStorage, Workspace, Plr)
    local Module = {
        Active = false,
        Mode = "None", -- "FS" یا "SH"
        Phase = "Idle",
        CurrentStyle = nil,
        SHIndex = 1,
        TargetMob = nil,
        Dest = nil,
        QuestEnabled = true,
        BossTarget = nil
    }

    local Sea = 1
    local Map = Workspace:WaitForChild("Map", 5)
    if Map then
        if Map:FindFirstChild("Dressrosa") or Map:FindFirstChild("Water7") then Sea = 2
        elseif Map:FindFirstChild("Zou") or Map:FindFirstChild("Turtle") then Sea = 3 end
    end

    local MasteryMobData = { Mob = "Water Fighter", QName = "ForgottenQuest", QId = 2, Pos = CFrame.new(-3053, 237, -10146) }

    local SHStyles = {
        {Name = "Dark Step", Check = {"BuyBlackLeg", true}, Equip = {"BuyBlackLeg"}, NPCPos = CFrame.new(-4842, 34, -4745)},
        {Name = "Electric", Check = {"BuyElectro", true}, Equip = {"BuyElectro"}, NPCPos = CFrame.new(-4842, 34, -4745)},
        {Name = "Water Kung Fu", Check = {"BuyFishmanKarate", true}, Equip = {"BuyFishmanKarate"}, NPCPos = CFrame.new(-4842, 34, -4745)},
        {Name = "Dragon Claw", Check = {"BlackbeardReward", "DragonClaw", "1"}, Equip = {"BlackbeardReward", "DragonClaw", "2"}, NPCPos = CFrame.new(710, 186, 653)}
    }

    local function GetMeleeMastery(styleName)
        local function checkTool(tool)
            if tool and tool:IsA("Tool") and tool.ToolTip == "Melee" then
                if styleName then if string.lower(tool.Name):find(string.lower(styleName)) then local lvl = tool:FindFirstChild("Level"); return tool.Name, lvl and lvl.Value or 0 end
                else local lvl = tool:FindFirstChild("Level"); return tool.Name, lvl and lvl.Value or 0 end
            end; return nil, 0
        end
        if Plr.Character then for _, tool in pairs(Plr.Character:GetChildren()) do local n, v = checkTool(tool); if n then return n, v end end end
        for _, tool in pairs(Plr.Backpack:GetChildren()) do local n, v = checkTool(tool); if n then return n, v end end
        return "هیچ میلی پیدا نشد", 0
    end

    local function GetPlayerBeli() local s, v = pcall(function() return Plr.Data.Beli.Value end); return s and v or 0 end
    local function GetPlayerFragments() local s, v = pcall(function() return Plr.Data.Fragments.Value end); return s and v or 0 end
    local function HasWaterKey() return Plr.Backpack:FindFirstChild("Water Key") ~= nil or (Plr.Character and Plr.Character:FindFirstChild("Water Key") ~= nil) end
    local function HasQuest() local s, v = pcall(function() return Plr.PlayerGui.Main.Quest.Visible end); return s and v == true end

    local function IsEnemyValid(E) if not E or not E.Parent then return false end; local h = E:FindFirstChild("Humanoid"); if not h or h.Health <= 0 then return false end; return E:FindFirstChild("HumanoidRootPart") ~= nil end
    local function FindEnemy(mobName)
        local root = Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart"); if not root then return nil end
        local fm, md = nil, math.huge; local enemies = Workspace:FindFirstChild("Enemies")
        if enemies then for _, v in pairs(enemies:GetChildren()) do pcall(function() if string.find(v.Name, mobName) and IsEnemyValid(v) then local d = (root.Position - v.HumanoidRootPart.Position).Magnitude; if d < md then md = d; fm = v end end end) end end
        return fm
    end

    function Module.StartFS(style) Module.Active = true; Module.Mode = "FS"; Module.CurrentStyle = style; Module.Phase = "CheckRequirements" end
    function Module.StartSH() Module.Active = true; Module.Mode = "SH"; Module.Phase = "Check"; Module.SHIndex = 1 end
    function Module.Stop() Module.Active = false; Module.Phase = "Idle"; Module.TargetMob = nil; Module.CurrentStyle = nil end

    function Module.Tick()
        if not Module.Active then return nil end
        local root = Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart")
        if not root then return nil end

        if Module.Mode == "FS" and Module.CurrentStyle then
            local style = Module.CurrentStyle
            if Module.Phase == "CheckRequirements" then
                if GetPlayerBeli() < style.Cost or (style.Fragments and GetPlayerFragments() < style.Fragments) then Module.Stop(); return nil end
                if style.ReqStyleName then
                    local res = ReplicatedStorage.Remotes.CommF_:InvokeServer(unpack(style.ReqCheck))
                    if tostring(res) ~= "1" then Module.Stop(); return nil end
                    local _, mastery = GetMeleeMastery(style.ReqStyleName)
                    if mastery < style.ReqMastery then Module.Phase = "EquipReq"; return nil end
                end
                if style.ReqKey and not HasWaterKey() then Module.Phase = "FarmBoss"; return nil end
                Module.Phase = "GoToNPC"
            elseif Module.Phase == "EquipReq" then
                Module.TargetMob = nil; Module.Dest = style.EquipPos
                if (root.Position - style.EquipPos.Position).Magnitude < 15 then ReplicatedStorage.Remotes.CommF_:InvokeServer(unpack(style.ReqEquip)); task.wait(1.5); Module.Phase = "MasteryFarm" end
            elseif Module.Phase == "MasteryFarm" then
                local _, mastery = GetMeleeMastery(style.ReqStyleName)
                if mastery >= style.ReqMastery then Module.Phase = "CheckRequirements"; return nil end
                if Module.QuestEnabled then
                    if HasQuest() then local mob = FindEnemy(MasteryMobData.Mob); if mob then Module.TargetMob = mob else Module.TargetMob = nil; Module.Dest = MasteryMobData.Pos * CFrame.new(0, 50, 0) end
                    else Module.TargetMob = nil; Module.Dest = MasteryMobData.Pos; if (root.Position - MasteryMobData.Pos.Position).Magnitude < 15 then pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", MasteryMobData.QName, MasteryMobData.QId) end); task.wait(0.5) end end
                else
                    local mob = FindEnemy(MasteryMobData.Mob); if mob then Module.TargetMob = mob else Module.TargetMob = nil; Module.Dest = MasteryMobData.Pos * CFrame.new(0, 50, 0) end
                end
            elseif Module.Phase == "FarmBoss" then
                if HasWaterKey() then Module.Phase = "GoToNPC"; return nil end
                local boss = FindEnemy(style.BossName); if boss then Module.TargetMob = boss else Module.TargetMob = nil; Module.Dest = style.BossPos * CFrame.new(0, 50, 0) end
            elseif Module.Phase == "GoToNPC" then
                Module.TargetMob = nil; Module.Dest = style.NPCPos
                if (root.Position - style.NPCPos.Position).Magnitude < 15 then Module.Phase = "Buy" end
            elseif Module.Phase == "Buy" then
                ReplicatedStorage.Remotes.CommF_:InvokeServer(style.RemoteArg); task.wait(1)
                Module.Stop()
            end

        elseif Module.Mode == "SH" then
            if Module.Phase == "Check" then
                if GetPlayerBeli() < 3000000 then Module.Stop(); return nil end
                Module.Phase = "ProcessStyle"; Module.SHIndex = 1
            elseif Module.Phase == "ProcessStyle" then
                if Module.SHIndex > 4 then Module.Phase = "BuySH"; return nil end
                local style = SHStyles[Module.SHIndex]
                Module.TargetMob = nil; Module.Dest = style.NPCPos
                if (root.Position - style.NPCPos.Position).Magnitude < 15 then
                    ReplicatedStorage.Remotes.CommF_:InvokeServer(unpack(style.Equip)); task.wait(1.5)
                    local _, mastery = GetMeleeMastery()
                    if mastery >= 300 then Module.SHIndex = Module.SHIndex + 1 else Module.Phase = "Farm" end
                end
            elseif Module.Phase == "Farm" then
                local _, mastery = GetMeleeMastery()
                if mastery >= 300 then Module.Phase = "ProcessStyle"; return nil end
                if Module.QuestEnabled then
                    if HasQuest() then local mob = FindEnemy(MasteryMobData.Mob); if mob then Module.TargetMob = mob else Module.TargetMob = nil; Module.Dest = MasteryMobData.Pos * CFrame.new(0, 50, 0) end
                    else Module.TargetMob = nil; Module.Dest = MasteryMobData.Pos; if (root.Position - MasteryMobData.Pos.Position).Magnitude < 15 then pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", MasteryMobData.QName, MasteryMobData.QId) end); task.wait(0.5) end end
                else
                    local mob = FindEnemy(MasteryMobData.Mob); if mob then Module.TargetMob = mob else Module.TargetMob = nil; Module.Dest = MasteryMobData.Pos * CFrame.new(0, 50, 0) end
                end
            elseif Module.Phase == "BuySH" then
                Module.TargetMob = nil; Module.Dest = CFrame.new(1400, 247, -5181)
                if (root.Position - Module.Dest.Position).Magnitude < 15 then
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("BuySuperhuman"); task.wait(1)
                    Module.Stop()
                end
            end
        end

        -- بازگرداندن تارگت برای اسکریپت اصلی
        if Module.TargetMob then return {Mode = "Mob", Instance = Module.TargetMob}
        elseif Module.Dest then return {Mode = (Module.QuestEnabled and not HasQuest()) and "NPC" or "Wait", CFrame = Module.Dest} end
        return nil
    end

    return Module
end
