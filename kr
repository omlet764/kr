local CachedDealerFruits = "در حال محاسبه..."
local LastDealerCheckCycle = -1
task.spawn(function()
    while task.wait(5) do
        local cCycle = math.floor(os.time() / 14400)
        if LastDealerCheckCycle ~= cCycle then
            pcall(function()
                local stock = ReplicatedStorage.Remotes.CommF_:InvokeServer("GetFruits", false)
                if type(stock) == "table" then
                    local onSale = {}
                    for _, f in pairs(stock) do if f.OnSale then table.insert(onSale, getCleanName(f.Name)) end end
                    CachedDealerFruits = table.concat(onSale, " ، ")
                    if CachedDealerFruits == "" then CachedDealerFruits = "هیچ فروتی موجود نیست" end
                    LastDealerCheckCycle = cCycle
                end
            end)
        end
    end
end)

task.spawn(function()
    while task.wait(1.5) do
        pcall(function()
            local lvl = GetMyLevel()
            local money = formatNumber(GetPlayerBeli())
            local frags = formatNumber(GetPlayerFragments())
            local fishCaught = Extra.Get("TotalFishCaught") or 0

            local actionStr = "بیکار"
            if FarmMode == "LevelUp" then actionStr = "درحال لول آپ"
            elseif FarmMode == "BossFarm" then actionStr = "درحال کشتن باس"
            elseif FarmMode == "Chest" then actionStr = "درحال جمع آوری چست"
            elseif FarmMode == "Fruit" then actionStr = "درحال رفتن به سمت میوه"
            elseif FarmMode == "DoughKing" then actionStr = "درحال فارم دوج کینگ"
            elseif FarmMode == "FightingStyle" then
                actionStr = "درحال خرید فایتینگ استایل"
                if FSState.CurrentStyle then actionStr = actionStr .. " (" .. FSState.CurrentStyle.Name .. " - " .. FSState.Phase .. ")" end
            elseif Extra.Get("IsRolling") then actionStr = "توقف موقت برای رول گاچا"
            elseif RaidConfig.RaidEnabled then actionStr = "درحال انجام رید"
            elseif Extra.Get("AutoFish") then actionStr = "درحال ماهیگیری (Auto Fish)"
            elseif FarmMode == "GettingBoat" then actionStr = "درحال خرید قایق قایق"
            elseif FarmMode == "AutoSea" then actionStr = "درحال فارم در دریا"
            elseif FarmMode == "Respawning" then actionStr = " (Respawn)"
            elseif FarmMode == "IslandTeleport" then actionStr = "درحال تلپورت به جزیره"
            end

            local meleeName, masteryLevel = GetMeleeMastery(nil)
            local masteryStr = meleeName .. " | مستری: " .. tostring(masteryLevel)

            local bossesStr = ""
            for _, d in ipairs(BossDatabase) do
                if IsBossSpawned(d.Mob) then bossesStr = bossesStr .. d.Mob .. " ، " end
            end
            if bossesStr == "" then bossesStr = "هیچ باسی اسپان نشده" else bossesStr = string.sub(bossesStr, 1, -4) end

            local checkTime = ReplicatedStorage.Remotes.CommF_:InvokeServer("Cousin", "CheckTime", "DLCBoxData")
            local canBuy = ReplicatedStorage.Remotes.CommF_:InvokeServer("Cousin", "CheckCanBuyType", "DLCBoxData")
            local timeReady = (checkTime == true or tostring(checkTime):lower():find("true") or checkTime == 0 or tostring(checkTime):lower():find("ready"))
            local moneyReady = (canBuy == 1 or canBuy == true or tostring(canBuy) == "1" or tostring(canBuy) == "true")
            local gachaStr = ""
            if timeReady then gachaStr = "آماده رول!"
            else local cleanTime = tostring(checkTime):match("%d+:[%d:]+"); if cleanTime then gachaStr = "مانده: " .. cleanTime else gachaStr = "در حال محاسبه..." end end
            if not moneyReady then gachaStr = gachaStr .. " | ❌ پولت کافی نیست" end

            local fruitsStr = ""
            for _, v in pairs(Workspace:GetChildren()) do
                if (v:IsA("Tool") or v:IsA("Model")) and string.find(v.Name,"Fruit") and not string.find(v.Name,"Dealer") and not string.find(v.Name,"Gacha") and not string.find(v.Name,"Blox Fruit") then
                    fruitsStr = fruitsStr .. getCleanName(v.Name) .. " ، "
                end
            end
            if fruitsStr == "" then fruitsStr = "هیچ میوه‌ای روی زمین نیست" else fruitsStr = string.sub(fruitsStr, 1, -4) end

            StatusPanel:SetDesc(
                "🔰 لول فعلی: " .. lvl ..
                "\n\n💵 موجودی پول: $" .. money ..
                "\n\n💎 فرگمنت: " .. frags ..
                "\n\n🥋 میلی فعلی: " .. masteryStr ..
                "\n\n🎣 ماهی های گرفته شده: " .. fishCaught ..
                "\n\n⚙️ وضعیت پلیر: " .. actionStr ..
                "\n\n🎁 چست‌های جمع شده: " .. TotalChestsCollected ..
                "\n\n🎰 وضعیت گاچا: " .. gachaStr ..
                "\n\n🏪 فروت‌های موجود در دیلر: " .. CachedDealerFruits ..
                "\n\n💀 باس‌های موجود: " .. bossesStr ..
                "\n\n🍎 میوه‌های روی زمین: " .. fruitsStr
            )
        end)
    end
end)

