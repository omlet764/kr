-- سیستم توین فوق هوشمند (Super Smart Tween) با تخمین مسیر
-- ==========================================
local LastFastTeleport = 0
local function SmartTween(root, targetCFrame, activeTween)
    if not root then return nil end
    local myPos = root.Position
    local targetPos = targetCFrame.Position
    local dist = (myPos - targetPos).Magnitude

    if dist < 10 then
        root.CFrame = targetCFrame
        if activeTween then activeTween:Cancel() end
        return nil
    end

    if tick() - LastFastTeleport > 3 then
        local teleported = false
        
        if Sea == 1 then
            local distFishman = (myPos - Vector3.new(61163, 11, 1819)).Magnitude
            local targetDistFishman = (targetPos - Vector3.new(61163, 11, 1819)).Magnitude
            
            local distSky1 = (targetPos - Vector3.new(-4607, 874, -1667)).Magnitude
            local myDistSky1 = (myPos - Vector3.new(-4607, 874, -1667)).Magnitude
            
            local distSky2 = (targetPos - Vector3.new(-7894, 5547, -380)).Magnitude
            local myDistSky2 = (myPos - Vector3.new(-7894, 5547, -380)).Magnitude

            if distFishman > 3000 and targetDistFishman < 3000 then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(61163.85, 11.68, 1819.78))
                teleported = true
            elseif distFishman < 3000 and targetDistFishman > 3000 then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(3864.69, 6.74, -1926.21))
                teleported = true
            elseif targetDistFishman > 3000 then
                if distSky2 < 2000 and myDistSky2 > 2000 then
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(-7894.61, 5547.14, -380.29))
                    teleported = true
                elseif distSky1 < 2000 and myDistSky1 > 2000 then
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(-4607.82, 874.39, -1667.55))
                    teleported = true
                end
            end

        elseif Sea == 2 then
            local distCursed = (myPos - Vector3.new(923, 126, 32852)).Magnitude
            local targetDistCursed = (targetPos - Vector3.new(923, 126, 32852)).Magnitude
            
            if distCursed > 3000 and targetDistCursed < 3000 then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(923.21, 126.97, 32852.83))
                teleported = true
            elseif distCursed < 3000 and targetDistCursed > 3000 then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(-6508.55, 89.03, -132.84))
                teleported = true
            end
        end

        if teleported then
            if activeTween then activeTween:Cancel() end
            LastFastTeleport = tick()
            task.wait(1.5)
            return nil
        end
    end

    local useCFrame = targetCFrame
    if dist > 300 then
        if myPos.Y > -500 and targetPos.Y > -500 then
            useCFrame = targetCFrame * CFrame.new(0, 40, 0)
        end
    end

    if activeTween then activeTween:Cancel() end
    local tween = TweenService:Create(root, TweenInfo.new(dist / Settings.FlightSpeed, Enum.EasingStyle.Linear), {CFrame = useCFrame})
    tween:Play()
    return tween
end

